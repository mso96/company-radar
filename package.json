{
  "name": "company-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "HOME=$PWD/.wrangler-home WRANGLER_LOG_PATH=$PWD/.wrangler/logs next dev --turbopack",
    "next:build": "next build",
    "build": "opennextjs-cloudflare build",
    "cf:build": "npm run build",
    "cf:deploy": "opennextjs-cloudflare deploy -- --keep-vars",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run cf:build && npm run cf:deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.22",
    "@opennextjs/cloudflare": "^1.14.8",
